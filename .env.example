# App runtime
APP_HOST=127.0.0.1
APP_PORT=8000
APP_ENV=development
LOCAL_PRIVATE_MODE=true
CORS_ALLOW_ORIGINS=http://127.0.0.1:8000,http://localhost:8000
SECURE_HEADERS_ENABLED=true
API_AUTH_ENABLED=false
API_AUTH_TOKEN=
MAX_UPLOAD_MB=20

# Model config (optional)
LLM_PROVIDER=auto
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6
AVAILABLE_MODELS=claude-sonnet-4-6,claude-opus-4-6,claude-haiku-4-5-20251001,claude-sonnet-4-5-20250929,gpt-4o-mini,gpt-4.1-mini,gpt-4.1

# Vector retrieval backend
VECTOR_BACKEND=local
CHROMA_PERSIST_DIR=/Users/maestro/LinkedIN analysis/creator_intelligence_app/data/indexes/chroma

# Graph data source
CREATOR_GRAPH_PATH=/Users/maestro/LinkedIN analysis/knowledge-graph.json

# Optional integrations
NOTION_ENABLED=false
NOTION_API_KEY=
NOTION_DATABASE_ID=
NOTION_PARENT_PAGE_ID=
GITHUB_EXPORT_ENABLED=false
GITHUB_TOKEN=
GITHUB_OWNER=
GITHUB_REPO=
GITHUB_BRANCH=main
GITHUB_PATH_PREFIX=

# Optional legacy Neo4j values
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=your-password
NEO4J_DATABASE=neo4j
# If strict TLS validation fails in your environment, use:
# NEO4J_URI=neo4j+ssc://<your-instance>.databases.neo4j.io
